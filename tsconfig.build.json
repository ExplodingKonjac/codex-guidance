{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "sourceMap": false,
    "outDir": "scripts",
    "rootDir": "src",
    "tsBuildInfoFile": "node_modules/.cache/tsc-build.tsbuildinfo"
  },
  "include": [
    "src/core/**/*.ts",
    "src/hook_entry.ts"
  ],
  "exclude": [
    "test/**/*.ts",
    "**/*.test.ts"
  ]
}
