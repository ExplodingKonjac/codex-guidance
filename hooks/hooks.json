{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hook_entry.js --hook session_start"
          }
        ],
        "description": "Load global Codex guidance at session start",
        "id": "codex-guidance:session-start"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hook_entry.js --hook user_prompt_submit"
          }
        ],
        "description": "Record the active Codex turn for guidance inheritance",
        "id": "codex-guidance:user-prompt-submit"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|mcp__.*read.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hook_entry.js --hook post_tool_use"
          }
        ],
        "description": "Load path-scoped Codex guidance after matching reads",
        "id": "codex-guidance:post-tool-use"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|apply_patch|mcp__.*write.*|mcp__.*edit.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hook_entry.js --hook pre_tool_use"
          }
        ],
        "description": "Load path-scoped Codex guidance before matching edits",
        "id": "codex-guidance:pre-tool-use"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hook_entry.js --hook pre_compact"
          }
        ],
        "description": "Prepare a Codex guidance compact boundary",
        "id": "codex-guidance:pre-compact"
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hook_entry.js --hook post_compact"
          }
        ],
        "description": "Complete a Codex guidance compact boundary",
        "id": "codex-guidance:post-compact"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hook_entry.js --hook stop"
          }
        ],
        "description": "Mark the active Codex guidance turn complete",
        "id": "codex-guidance:stop"
      }
    ]
  }
}
