{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hooks/session_start.js"
          }
        ],
        "description": "Load global Codex guidance at session start",
        "id": "codex-guidance:session-start"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|mcp__.*read.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hooks/post_tool_use.js"
          }
        ],
        "description": "Load path-scoped Codex guidance after matching reads",
        "id": "codex-guidance:post-tool-use"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|apply_patch|mcp__.*write.*|mcp__.*edit.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hooks/pre_tool_use.js"
          }
        ],
        "description": "Load path-scoped Codex guidance before matching edits",
        "id": "codex-guidance:pre-tool-use"
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/hooks/post_compact.js"
          }
        ],
        "description": "Advance Codex guidance generation after compaction",
        "id": "codex-guidance:post-compact"
      }
    ]
  }
}
