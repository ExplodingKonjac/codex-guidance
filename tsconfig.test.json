{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": ".test-dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,
    "tsBuildInfoFile": "node_modules/.cache/tsc-test.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
